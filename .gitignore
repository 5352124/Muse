# Git ignore for Muse project submodule
.gradle/
.idea/
.kotlin/
build/
*.iml
*.ipr
*.iws
local.properties
keystore.properties
*.keystore
*.jks
*.env
*.log
.DS_Store
Thumbs.db

# 项目文档（仅保留首页 README）
/docs/*
!/docs/README.md
!/docs/README_EN.md

# 贡献/安全/计划文档（项目代码不包含这些）
CONTRIBUTING.md
SECURITY.md
Muse_Product_Enhancement_Plan.md
_skill_existing.txt
report_*.txt

# 临时文件
compile_log2.txt
tmp_head.kt
tmp_*.kt

# 软著申请材料
软件著作权申请资料/
